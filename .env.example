# ─── Supabase ─────────────────────────────────────────────────
# Récupérer sur : supabase.com → votre projet → Settings → API
# Les clés commencent TOUJOURS par "eyJ" (format JWT)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App ──────────────────────────────────────────────────────
# En local : http://localhost:3000
# En prod  : https://votre-projet.vercel.app (sans slash final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX_UPLOADS=10
RATE_LIMIT_WINDOW_MS=3600000

# ─── Limites fichiers ─────────────────────────────────────────
MAX_FILE_SIZE_MB=500

# ─── Cleanup route (optionnel) ────────────────────────────────
# Uniquement nécessaire si vous appelez /api/cleanup en HTTP
# Le cleanup automatique est géré par pg_cron dans Supabase
# CRON_SECRET=votre-secret-aleatoire
